#!/bin/bash
set -euo pipefail

# Automatic backup script
#
# Link from:
# /etc/cron.weekly/

# ------------------------------------------------------------------------------
# Config (can be overriden by ENVVAR)
LOG_FILE=${LOG_FILE:-"/root/log/bkup.log"}
ERR_FILE=${LOG_FILE:-"/root/log/bkup_err.log"}
# ------------------------------------------------------------------------------

SELF_DIR=$(dirname "$(realpath "$0")")
ROOT=${SELF_DIR}/../backup

mkdir -p "$(dirname "${LOG_FILE}")"

"${ROOT}/bkup_full.py" \
    > >(tee -a "${LOG_FILE}") \
    2> >(tee -a "${ERR_FILE}" >&2)
